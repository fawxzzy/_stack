    "fitness:verify": "pnpm --dir ../fawxzzy-fitness verify:strict",
    "fitness:verify:clean": "pnpm --dir ../fawxzzy-fitness clean:next && pnpm --dir ../fawxzzy-fitness verify:strict",
    "fitness:git:disconnect": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness git disconnect --yes",
    "fitness:git:autodeploy:disable": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\Set-FitnessGitAutoDeploy.ps1 -ConfigPath .\\config\\fitness-deploy.identity.json -State disabled",
    "fitness:deploy:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\Test-FitnessDeployLink.ps1 -ConfigPath .\\config\\fitness-deploy.identity.json",
    "fitness:build:vercel": "pnpm run fitness:verify:clean && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness build --yes",
    "fitness:deploy:preview": "pnpm run fitness:deploy:preflight && pnpm run fitness:verify:clean && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy",
    "fitness:deploy:prod": "pnpm run fitness:deploy:preflight && pnpm run fitness:verify:clean && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prod --yes",
    "fitness:deploy:prebuilt": "pnpm run fitness:deploy:preflight && pnpm run fitness:build:vercel && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt",
    "fitness:deploy:prebuilt:prod": "pnpm run fitness:deploy:preflight && pnpm run fitness:build:vercel && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt --prod",
    "fitness:deploy:preview:logs": "pnpm run fitness:deploy:preflight && pnpm run fitness:verify:clean && pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --logs",
