    "mazer:dev": "npm --prefix ../mazer run dev -- --host 0.0.0.0",
    "mazer:dev:open": "ops\\bin\\mazer-dev.cmd",
    "mazer:preview": "npm --prefix ../mazer run build && pnpm --dir ../mazer exec vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "mazer:preview:open": "ops\\bin\\mazer-preview.cmd",
    "mazer:deploy:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\Test-MazerDeployIdentity.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\Test-MazerDeployLink.ps1 -ConfigPath .\\config\\mazer-deploy.identity.json",
    "mazer:deploy:preview": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\Invoke-MazerDeploy.ps1 -Target preview",
