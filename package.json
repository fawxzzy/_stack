    "codex:stack:inbox:bootstrap:once": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Start-CodexInboxRunner.ps1 -ConfigPath .\\ops\\codex\\repos\\stack\\config.toml -RunOnce -Model gpt-5.4 -Reasoning high -Speed standard -SandboxMode danger-full-access -ApprovalPolicy never -WebSearch disabled",
    "codex:stack:task": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Invoke-CodexRepoTask.ps1 -ConfigPath .\\ops\\codex\\repos\\stack\\config.toml",
    "codex:stack:task:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Invoke-CodexRepoTask.ps1 -ConfigPath .\\ops\\codex\\repos\\stack\\config.toml -Model gpt-5.4 -Reasoning high -Speed standard -SandboxMode danger-full-access -ApprovalPolicy never -WebSearch disabled",
