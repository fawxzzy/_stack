{
  "repos": {
    "stack": {
      "path": ".",
      "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Test-StackOperatorSurface.ps1 && git diff --check",
      "deployModel": "operator-layer",
      "codexLocalLanding": "ff-only-local-main",
      "codexBaseRefRule": "prefer-origin-main-else-local-main"
    },
    "fitness": {
      "path": "../fawxzzy-fitness",
      "verify": "pnpm verify:strict",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../fawxzzy-fitness deploy",
      "deployPreviewPrebuilt": "pnpm dlx vercel --cwd ../fawxzzy-fitness deploy --prebuilt",
      "deployProd": "pnpm dlx vercel --cwd ../fawxzzy-fitness deploy --prod",
      "deployProdPrebuilt": "pnpm dlx vercel --cwd ../fawxzzy-fitness deploy --prebuilt --prod"
    },
    "mazer": {
      "path": "../fawxzzy-mazer",
      "verify": "npm run lint && npm run test && npm run build",
      "localDev": "npm run dev -- --host 0.0.0.0",
      "localPreview": "npm run build && pnpm --dir ../fawxzzy-mazer exec vite preview --host 0.0.0.0 --port 4173 --strictPort",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../fawxzzy-mazer deploy",
      "deployProd": "pnpm dlx vercel --cwd ../fawxzzy-mazer deploy --prod"
    },
    "playbook": {
      "path": "../fawxzzy-playbook",
      "deployModel": "self-hosted"
    },
    "lifeline": {
      "path": "../fawxzzy-lifeline",
      "deployModel": "self-hosted"
    },
    "atlas": {
      "path": "../fawxzzy-atlas",
      "deployModel": "self-hosted"
    }
  }
}
