{
  "repos": {
    "stack": {
      "path": ".",
      "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Test-StackOperatorSurface.ps1 && git diff --check",
      "deployModel": "operator-layer",
      "queueOrRegistryCommands": [
        "pnpm run stack:queue-or-registry:follow-on",
        "pnpm run stack:queue-or-registry:live-direct-json-read-follow-on",
        "pnpm run stack:queue-or-registry:live-directory-read-follow-on",
        "pnpm run stack:queue-or-registry:broader-execution-behavior",
        "pnpm run stack:queue-or-registry:execution-bridge-artifacts",
        "pnpm run stack:queue-or-registry:worker-artifact-emission",
        "pnpm run stack:queue-or-registry:queue-drop-emission",
        "pnpm run stack:queue-or-registry:launch-or-dispatch",
        "pnpm run stack:queue-or-registry:claim-state-movement",
        "pnpm run stack:queue-or-registry:done-state-closure",
        "pnpm run stack:queue-or-registry:merge-request-artifact-behavior",
        "pnpm run stack:queue-or-registry:paused-status-artifact-behavior",
        "pnpm run stack:queue-or-registry:merger-assignment-artifact-behavior",
        "pnpm run stack:queue-or-registry:resume-context-artifact-behavior",
        "pnpm run stack:queue-or-registry:merge-completion-behavior"
      ],
      "codexLocalLanding": "ff-only-local-main",
      "codexBaseRefRule": "prefer-origin-main-else-local-main"
    },
    "fitness": {
      "path": "../fawxzzy-fitness",
      "verify": "pnpm verify:strict",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy",
      "deployPreviewPrebuilt": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt",
      "deployProd": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prod --yes",
      "deployProdPrebuilt": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt --prod"
    },
    "mazer": {
      "path": "../mazer",
      "verify": "npm run lint && npm run test && npm run build",
      "localDev": "npm run dev -- --host 0.0.0.0",
      "localPreview": "npm run build && pnpm --dir ../mazer exec vite preview --host 0.0.0.0 --port 4173 --strictPort",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../mazer deploy",
      "deployProd": "pnpm dlx vercel --cwd ../mazer deploy --prod"
    },
    "trove": {
      "path": "../trove",
      "verify": "npm run verify",
      "localDev": "npm run dev",
      "localPreview": "npm run build && npm run start",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../trove deploy",
      "deployPreviewPrebuilt": "pnpm dlx vercel --cwd ../trove deploy --prebuilt",
      "deployProd": "pnpm dlx vercel --cwd ../trove deploy --prod",
      "deployProdPrebuilt": "pnpm dlx vercel --cwd ../trove deploy --prebuilt --prod"
    },
    "playbook": {
      "path": "../fawxzzy-playbook",
      "deployModel": "self-hosted"
    },
    "lifeline": {
      "path": "../fawxzzy-lifeline",
      "deployModel": "self-hosted"
    },
    "atlas": {
      "path": "../..",
      "deployModel": "self-hosted"
    }
  }
}
