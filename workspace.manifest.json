{
  "repos": {
    "stack": {
      "path": ".",
      "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Test-StackOperatorSurface.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File .\\ops\\codex\\Test-AtlasWorkspaceWriter.ps1 && git diff --check",
      "deployModel": "operator-layer",
      "codexLocalLanding": "ff-only-local-main",
      "codexBaseRefRule": "prefer-origin-main-else-local-main",
      "codexExecutionClasses": {
        "repoLocalWorktree": {
          "command": "pnpm run codex:stack:task -- -PromptPath C:\\path\\to\\prompt.md",
          "executionClass": "repo_local_worktree",
          "rootPolicy": "repo-local-only"
        },
        "atlasCanonicalWorkspaceWriter": {
          "command": "pnpm run codex:atlas-workspace:task -- -PromptPath C:\\path\\to\\prompt.md -CanonicalRootPath C:\\ATLAS",
          "executionClass": "canonical_workspace",
          "rootPolicy": "explicit-canonical-root-only",
          "defaultMode": "read-only",
          "safetyContracts": [
            "exclusive writer lock",
            "dirty-path snapshot with digests",
            "exact-path mutation admission",
            "exact-path staging only",
            "manual-only push"
          ]
        }
      },
      "codexRuntimePolicy": {
        "rule": "explicit-runtime-policy",
        "envelope": "precedence-resolved-and-receipted",
        "precedence": [
          "explicit-command-argument",
          "prompt-metadata",
          "repo-config",
          "shared-defaults"
        ],
        "defaultPosture": {
          "model": "gpt-5.6-sol",
          "reasoning": "xhigh",
          "speed": "standard",
          "permissions": "full-access",
          "permissionProfile": ":danger-full-access",
          "approval": "never",
          "webSearch": "live"
        },
        "bootstrapCompatibility": {
          "sandboxMode": "danger-full-access",
          "reason": "last accepted static-model bootstrap path"
        },
        "receiptFields": [
          "requested",
          "resolved",
          "sources",
          "codex_version",
          "warnings",
          "blockers"
        ],
        "atlasContractsV2": {
          "producer": "stack",
          "validator": "atlas-root-owned-cli",
          "runManifestField": "atlasContractsV2",
          "artifacts": [
            "atlas.component-manifest.v2.json",
            "atlas.job-envelope.v2.json",
            "atlas.execution-receipt.v2.json"
          ],
          "externalAuthorityDefault": "denied"
        },
        "pushPolicy": "manual-only"
      },
      "scheduledInbox": {
        "executionMode": "run-once",
        "taskName": "AtlasStackInboxSweep",
        "cadence": "PT5M",
        "multipleInstancesPolicy": "IgnoreNew",
        "applicationLease": "atomic-exclusive-process-identity",
        "freshnessMinutes": 30,
        "runtimePlacement": "runtime/codex/stack",
        "promptLifecycle": [
          "inbox",
          "processing-claim",
          "terminal-archive-or-quarantine"
        ]
      }
    },
    "fitness": {
      "path": "../fawxzzy-fitness",
      "verify": "pnpm verify:strict",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy",
      "deployPreviewPrebuilt": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt",
      "deployProd": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prod --yes",
      "deployProdPrebuilt": "pnpm dlx vercel@51.6.1 --cwd ../fawxzzy-fitness deploy --prebuilt --prod"
    },
    "discordos": {
      "path": "../DiscordOS",
      "verify": "npm run verify",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../DiscordOS deploy",
      "productionApproval": {
        "required": true,
        "scope": "current-thread-per-project",
        "contract": "Vercel production deployment requires explicit current-thread approval for the named DiscordOS project; generic approval does not qualify."
      }
    },
    "mazer": {
      "path": "../fawxzzy-mazer",
      "verify": "npm run lint && npm run test && npm run build",
      "localDev": "npm run dev -- --host 0.0.0.0",
      "localPreview": "npm run build && pnpm --dir ../fawxzzy-mazer exec vite preview --host 0.0.0.0 --port 4173 --strictPort",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../fawxzzy-mazer deploy",
      "deployProd": "pnpm dlx vercel --cwd ../fawxzzy-mazer deploy --prod"
    },
    "trove": {
      "path": "../fawxzzy-trove",
      "verify": "npm run verify",
      "localDev": "npm run dev",
      "localPreview": "npm run build && npm run start",
      "deployModel": "vercel-cli",
      "deployPreview": "pnpm dlx vercel --cwd ../fawxzzy-trove deploy",
      "deployPreviewPrebuilt": "pnpm dlx vercel --cwd ../fawxzzy-trove deploy --prebuilt",
      "deployProd": "pnpm dlx vercel --cwd ../fawxzzy-trove deploy --prod",
      "deployProdPrebuilt": "pnpm dlx vercel --cwd ../fawxzzy-trove deploy --prebuilt --prod"
    },
    "playbook": {
      "path": "../playbook",
      "deployModel": "self-hosted"
    },
    "lifeline": {
      "path": "../lifeline",
      "deployModel": "self-hosted"
    },
    "atlas": {
      "path": "../..",
      "deployModel": "self-hosted"
    }
  }
}
