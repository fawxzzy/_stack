{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas://packages/contracts/atlas.github.event-receipt.v1.schema.json",
  "title": "Atlas GitHub event receipt contract v1",
  "description": "Immutable normalized GitHub facts emitted by _stack before Atlas admission and any downstream projection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "event_id", "idempotency_key", "observed_at", "event_family", "fact_state", "source", "subject", "correlation", "evidence_refs", "digest", "normalized_facts", "authority"],
  "properties": {
    "contract_version": {"type": "string", "const": "atlas.github.event-receipt.v1"},
    "event_id": {"type": "string", "pattern": "^ghr_[a-z0-9][a-z0-9_-]*$"},
    "idempotency_key": {"type": "string", "pattern": "^ghk_[a-z0-9][a-z0-9_-]*$"},
    "observed_at": {"type": "string", "format": "date-time"},
    "event_family": {"type": "string", "enum": ["repository", "branch", "pull_request", "issue", "workflow_run", "release", "security_alert"]},
    "fact_state": {"type": "string", "enum": ["observed", "empty", "unknown", "access_denied", "disabled", "conflicting", "not_applicable"]},
    "source": {"$ref": "#/$defs/source"},
    "subject": {"$ref": "#/$defs/subject"},
    "correlation": {"$ref": "#/$defs/correlation"},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "digest": {"$ref": "#/$defs/digest"},
    "normalized_facts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fact"}},
    "authority": {"$ref": "#/$defs/authority"},
    "summary": {"type": ["string", "null"], "minLength": 1},
    "extensions": {"type": "object"}
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "producer", "repository_owner", "repository_name", "endpoint"],
      "properties": {
        "provider": {"type": "string", "const": "github"},
        "producer": {"type": "string", "const": "_stack"},
        "repository_owner": {"type": "string", "minLength": 1},
        "repository_name": {"type": "string", "minLength": 1},
        "endpoint": {"type": "string", "minLength": 1}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "repository_id", "entity_type", "entity_id", "entity_ref", "title", "url"],
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "repository_id": {"type": ["string", "null"], "minLength": 1},
        "entity_type": {"type": "string", "enum": ["repository", "branch", "pull_request", "issue", "workflow_run", "release", "security_alert"]},
        "entity_id": {"type": ["string", "null"], "minLength": 1},
        "entity_ref": {"type": ["string", "null"], "minLength": 1},
        "title": {"type": ["string", "null"], "minLength": 1},
        "url": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_delivery_id", "source_run_id", "atlas_job_id", "parent_event_id"],
      "properties": {
        "provider_delivery_id": {"type": ["string", "null"], "minLength": 1},
        "source_run_id": {"type": ["string", "null"], "minLength": 1},
        "atlas_job_id": {"type": ["string", "null"], "minLength": 1},
        "parent_event_id": {"type": ["string", "null"], "pattern": "^ghr_[a-z0-9][a-z0-9_-]*$"}
      }
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "source_event_identity", "fact_payload_identity"],
      "properties": {
        "algorithm": {"type": "string", "const": "sha256"},
        "value": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_event_identity": {"type": "string", "minLength": 1},
        "fact_payload_identity": {"type": "string", "minLength": 1}
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_key", "state", "value", "source_path", "note"],
      "properties": {
        "fact_key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "state": {"type": "string", "enum": ["observed", "empty", "unknown", "access_denied", "disabled", "conflicting", "not_applicable"]},
        "value": {"type": ["string", "null"], "minLength": 1},
        "source_path": {"type": "string", "minLength": 1},
        "note": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer", "atlas_contract_owner", "owner_repository_truth", "read_only_first", "external_mutation"],
      "properties": {
        "producer": {"type": "string", "const": "_stack"},
        "atlas_contract_owner": {"type": "string", "const": "Atlas Contracts"},
        "owner_repository_truth": {"type": "string", "const": "preserved"},
        "read_only_first": {"type": "boolean", "const": true},
        "external_mutation": {"type": "string", "const": "denied"}
      }
    }
  }
}
