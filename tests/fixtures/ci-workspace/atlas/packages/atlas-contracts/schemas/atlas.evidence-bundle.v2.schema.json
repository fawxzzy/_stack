{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"atlas://packages/contracts/atlas.evidence-bundle.v2.schema.json","title":"ATLAS evidence bundle contract v2","type":"object","additionalProperties":false,
  "required":["contract_version","bundle_id","job_id","recorded_at","environment","evidence","classifications"],
